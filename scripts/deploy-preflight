#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TARGET="${1:-platform}"

usage() {
  cat <<'EOF'
Usage:
  scripts/deploy-preflight [platform|cloud-console|omnichannel|mcp]

Targets:
  platform      Full monorepo verification
  cloud-console Build validation for apps/cloud-console
  omnichannel   Go test validation for omnichannel backend sources
  mcp           Go test + build validation for the MCP gateway service
EOF
}

case "$TARGET" in
  platform)
    (
      cd "$ROOT_DIR"
      npm run test
    )
    ;;
  cloud-console)
    (
      cd "$ROOT_DIR"
      npx nx run cloud-console:test --outputStyle=static
    )
    ;;
  omnichannel)
    (
      cd "$ROOT_DIR"
      npx nx run omnichannel-api:test --outputStyle=static
      npx nx run omnichannel-api:build --outputStyle=static
      npx nx run omnichannel-worker:test --outputStyle=static
      npx nx run omnichannel-worker:build --outputStyle=static
    )
    ;;
  mcp)
    (
      cd "$ROOT_DIR"
      npx nx run mcp:test --outputStyle=static
      npx nx run mcp:build --outputStyle=static
    )
    ;;
  *)
    usage
    exit 1
    ;;
esac

echo "deploy-preflight: $TARGET passed"
