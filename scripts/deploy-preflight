#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TARGET="${1:-platform}"
REQUIRED_NODE="20.19.0"

usage() {
  cat <<'EOF'
Usage:
  scripts/deploy-preflight [platform|cloud-console|omnichannel|access-api]

Targets:
  platform      Full monorepo verification
  cloud-console Build validation for apps/cloud-console
  omnichannel   Build + test validation for omnichannel backend stack
  access-api    Build + test validation for services/access-api
EOF
}

require_file() {
  local path="$1"
  if [[ ! -f "$path" ]]; then
    echo "missing required file: $path"
    exit 1
  fi
}

cmp_version_ge() {
  local current="$1"
  local required="$2"
  local first
  first="$(printf "%s\n%s\n" "$required" "$current" | sort -V | head -n1)"
  [[ "$first" == "$required" ]]
}

require_node_version() {
  local current
  current="$(node -v | sed 's/^v//')"
  if ! cmp_version_ge "$current" "$REQUIRED_NODE"; then
    echo "node version too old: v$current (required >= v$REQUIRED_NODE)"
    echo "hint: run 'nvm install && nvm use' from repo root"
    exit 1
  fi
}

case "$TARGET" in
  platform)
    "$ROOT_DIR/scripts/doctor"
    "$ROOT_DIR/scripts/verify" all
    ;;
  cloud-console)
    require_node_version
    require_file "$ROOT_DIR/package-lock.json"
    (
      cd "$ROOT_DIR"
      if [[ -d node_modules ]]; then
        npm install
      else
        npm ci
      fi
      npm run build --workspace=@x/cloud-console
    )
    ;;
  omnichannel)
    require_node_version
    require_file "$ROOT_DIR/services/omnichannel/docker-compose.yml"
    (
      cd "$ROOT_DIR/services/omnichannel/backend"
      GOCACHE=/tmp/go-cache go test ./...
      GOCACHE=/tmp/go-cache go build ./cmd/api
      GOCACHE=/tmp/go-cache go build ./cmd/worker
    )
    ;;
  access-api)
    require_file "$ROOT_DIR/services/access-api/go.mod"
    (
      cd "$ROOT_DIR/services/access-api"
      GOCACHE=/tmp/go-cache go test ./...
      GOCACHE=/tmp/go-cache go build ./cmd/api
    )
    ;;
  *)
    usage
    exit 1
    ;;
esac

echo "deploy-preflight: $TARGET passed"
