#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
MODE="${1:-all}"

usage() {
  cat <<'EOF'
Usage:
  scripts/verify [all|platform|apps|agents|docs]

Modes:
  all      Run platform, apps, agent, and docs checks
  platform Run Go/Rust service checks
  apps     Run web app checks
  agents   Run agent blueprint checks
  docs     Run docs site checks
EOF
}

case "$MODE" in
  all)
    cd "$ROOT_DIR"
    npm run test
    ;;
  platform)
    cd "$ROOT_DIR"
    npm run test:platform
    ;;
  apps)
    cd "$ROOT_DIR"
    npm run test:apps
    ;;
  agents)
    cd "$ROOT_DIR"
    npm run test:agents
    ;;
  docs)
    cd "$ROOT_DIR"
    npm run test:docs
    ;;
  *)
    usage
    exit 1
    ;;
esac

echo "test surface passed: $MODE"
