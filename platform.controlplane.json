{
  "version": "1",
  "accounts": [
    {
      "name": "default"
    }
  ],
  "projects": [
    {
      "name": "cloud-console",
      "desired_state": "present",
      "gcp": {
        "project_id": "my-gcp-project",
        "region": "us-central1",
        "services": [
          "run.googleapis.com",
          "cloudresourcemanager.googleapis.com",
          "iam.googleapis.com"
        ]
      },
      "deployments": [
        {
          "name": "console-web",
          "provider": "gcp-cloud-run",
          "service": "console-web",
          "region": "us-central1",
          "environment": "production",
          "desired_state": "present"
        }
      ],
      "domains": [
        {
          "name": "anmhela.com",
          "provider": "cloudflare",
          "zone_id": "cf_zone_anmhela",
          "desired_state": "present",
          "project": "cloud-console",
          "records": [
            {
              "type": "CNAME",
              "name": "c",
              "content": "cname.vercel-dns.com",
              "ttl": 300,
              "desired_state": "present",
              "deployment_link": {
                "project": "cloud-console",
                "deployment_id": "console-web",
                "host": "console-web"
              }
            }
          ]
        },
        {
          "name": "anmhela.com",
          "provider": "vercel",
          "desired_state": "present",
          "project": "cloud-console",
          "records": [
            {
              "type": "CNAME",
              "name": "c",
              "content": "cname.vercel-dns.com",
              "ttl": 300,
              "desired_state": "present",
              "deployment_link": {
                "project": "cloud-console",
                "deployment_id": "console-web",
                "host": "console-web"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "omnichannel-api",
      "desired_state": "present",
      "gcp": {
        "project_id": "my-gcp-project",
        "region": "us-central1",
        "services": [
          "run.googleapis.com",
          "secretmanager.googleapis.com"
        ]
      },
      "deployments": [
        {
          "name": "omnichannel-api",
          "provider": "gcp-cloud-run",
          "service": "omnichannel-api",
          "region": "us-central1",
          "environment": "production",
          "desired_state": "present"
        }
      ]
    },
    {
      "name": "omnichannel-worker",
      "desired_state": "present",
      "gcp": {
        "project_id": "my-gcp-project",
        "region": "us-central1",
        "services": [
          "run.googleapis.com",
          "secretmanager.googleapis.com"
        ]
      },
      "deployments": [
        {
          "name": "omnichannel-worker",
          "provider": "gcp-cloud-run",
          "service": "omnichannel-worker",
          "region": "us-central1",
          "environment": "production",
          "desired_state": "present"
        }
      ]
    },
    {
      "name": "mcp",
      "desired_state": "present",
      "gcp": {
        "project_id": "my-gcp-project",
        "region": "us-central1",
        "services": [
          "run.googleapis.com",
          "secretmanager.googleapis.com"
        ]
      },
      "deployments": [
        {
          "name": "mcp",
          "provider": "gcp-cloud-run",
          "service": "mcp",
          "region": "us-central1",
          "environment": "production",
          "desired_state": "present"
        }
      ]
    }
  ]
}
