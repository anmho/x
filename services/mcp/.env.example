# MCP HTTP Gateway — environment variables

# `platform mcp setup` can generate a Docker-ready env file with these values
# under ~/.x-mcp/mcp.env by default.

# Port to listen on (default: 8765)
MCP_PORT=8765

# Comma-separated list of API keys.
# If not set, a key is auto-generated and saved to MCP_KEYS_FILE.
# MCP_API_KEYS=mcp_your_key_here

# Path to persisted keys file (default: ~/.x-mcp/keys.json)
# MCP_KEYS_FILE=/path/to/keys.json

# Path to persisted collaboration mailbox store (default: ~/.x-mcp/collab.json)
# MCP_MAILBOX_FILE=/path/to/collab.json
# MCP_COLLAB_STORE=/path/to/collab.json

# Linear issue metadata enrichment for collaboration channels.
# Optional, but recommended if you want ANM-* issues resolved into title/state metadata.
# LINEAR_API_KEY=lin_api_key
# LINEAR_API_URL=https://api.linear.app/graphql

# Slack ingress/egress bridge configuration.
# If set, POST /slack/events will accept Slack Events API callbacks.
# If SLACK_BOT_TOKEN is also set, mailbox messages in linked Slack threads are mirrored back to Slack.
# SLACK_SIGNING_SECRET=your_slack_signing_secret
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# SLACK_API_URL=https://slack.com/api

# Upstream MCP proxy configuration for external providers.
# The gateway keeps centralized auth here and forwards MCP tool calls to another
# HTTP MCP endpoint instead of embedding every provider API directly.
#
# Shared defaults:
# MCP_PROXY_DEFAULT_URL=http://localhost:9000/mcp
# MCP_PROXY_DEFAULT_KEY=upstream_api_key
# MCP_PROXY_DEFAULT_HEADER=Authorization
# MCP_PROXY_DEFAULT_SCHEME=Bearer
#
# Provider-specific overrides are available for:
#   github
#   google_docs
#   google_search
#   perplexity
#   glean
#   yahoo
#   yahoo_finance
#   coinbase
#
# Example Google Docs passthrough to an upstream Google Workspace MCP:
# MCP_PROXY_GOOGLE_DOCS_URL=http://localhost:9100/mcp
# MCP_PROXY_GOOGLE_DOCS_KEY=workspace_proxy_key
# MCP_PROXY_GOOGLE_DOCS_TOOL=docs_document_get
#
# Example Google Search passthrough:
# MCP_PROXY_GOOGLE_SEARCH_URL=http://localhost:9200/mcp
# MCP_PROXY_GOOGLE_SEARCH_KEY=search_proxy_key
# MCP_PROXY_GOOGLE_SEARCH_TOOL=google_search
