# MCP HTTP Gateway — environment variables

# Port to listen on (default: 8765)
MCP_PORT=8765

# Comma-separated list of API keys.
# If not set, seed MCP_KEYS_FILE ahead of time with `./bin/mcp keys generate --local`.
# MCP_API_KEYS=mcp_your_key_here

# Path to persisted keys file (default: ~/.x-mcp/keys.json)
# MCP_KEYS_FILE=/path/to/keys.json
