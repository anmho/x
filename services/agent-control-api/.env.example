# Required
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/agent_control?sslmode=disable

# Optional — omit to run in stub mode (runs stored but not dispatched to Cloud Run)
CLOUD_RUN_JOB_NAME=projects/my-project/locations/us-central1/jobs/agent-runner
CLOUD_RUN_REGION=us-central1

# Optional
PORT=8090
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Optional mailbox dispatcher integration
# When MCP_MAILBOX_EVENTS_URL is set, the API tails mailbox events and forwards
# routed messages into PushRunEvent delivery for active runs.
MCP_MAILBOX_EVENTS_URL=http://127.0.0.1:8765/mailbox/events
MCP_API_KEY=
MCP_MAILBOX_FILE=$HOME/.x-mcp/collab.json
MCP_DISPATCH_STATE_FILE=$HOME/.x-agent-control/dispatcher.json
