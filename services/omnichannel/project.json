{
  "name": "sdk",
  "projectType": "library",
  "root": "services/omnichannel",
  "sourceRoot": "services/omnichannel/backend/proto",
  "targets": {
    "generate-go": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./scripts/sdk-core.sh generate-server",
        "cwd": "."
      }
    },
    "generate-es": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./scripts/sdk-core.sh generate-es",
        "cwd": "."
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./scripts/sdk-core.sh lint",
        "cwd": "."
      }
    },
    "push": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./scripts/sdk-core.sh push",
        "cwd": "."
      },
      "cache": false
    },
    "publish-es": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./scripts/sdk-core.sh publish-es",
        "cwd": "."
      },
      "cache": false
    },
    "publish-go": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./scripts/sdk-core.sh publish-go",
        "cwd": "."
      },
      "cache": false
    },
    "publish": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./scripts/sdk-core.sh publish-all",
        "cwd": "."
      },
      "cache": false
    },
    "list": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./scripts/sdk-core.sh list",
        "cwd": "."
      },
      "cache": false
    }
  }
}
