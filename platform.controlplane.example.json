{
  "version": "1",
  "accounts": [
    {
      "name": "default",
      "secrets": [
        {
          "name": "access-api-admin-key",
          "desired_state": "present",
          "source_env": "ACCESS_API_ADMIN_KEY",
          "shares": [
            {
              "platform": "gcp",
              "project_id": "my-gcp-project",
              "name": "access-api-admin-key",
              "target_type": "project",
              "target_id": "access-api",
              "project": "access-api"
            },
            {
              "platform": "gcp",
              "project_id": "my-gcp-project",
              "name": "console-access-api-key",
              "target_type": "project",
              "target_id": "cloud-console",
              "project": "cloud-console"
            },
            {
              "platform": "vercel",
              "project_id": "cloud-console",
              "name": "ACCESS_API_ADMIN_KEY",
              "target_type": "application",
              "target_id": "console-web",
              "project": "cloud-console",
              "environments": [
                "development",
                "preview",
                "production"
              ]
            },
            {
              "platform": "gcp",
              "project_id": "my-gcp-project",
              "name": "template-studio-access-api-key",
              "target_type": "deployment",
              "target_id": "template-studio",
              "project": "omnichannel-api"
            }
          ]
        }
      ]
    }
  ],
  "projects": [
    {
      "name": "cloud-console",
      "desired_state": "present",
      "gcp": {
        "project_id": "my-gcp-project",
        "region": "us-central1",
        "services": [
          "run.googleapis.com",
          "cloudresourcemanager.googleapis.com",
          "iam.googleapis.com"
        ]
      },
      "deployments": [
        {
          "name": "console-web",
          "provider": "gcp-cloud-run",
          "service": "console-web",
          "region": "us-central1",
          "environment": "production",
          "desired_state": "present"
        }
      ],
      "domains": [
        {
          "name": "anmhela.com",
          "provider": "cloudflare",
          "zone_id": "cf_zone_anmhela",
          "desired_state": "present",
          "project": "cloud-console",
          "records": [
            {
              "type": "CNAME",
              "name": "c",
              "content": "cname.vercel-dns.com",
              "ttl": 300,
              "desired_state": "present",
              "deployment_link": {
                "project": "cloud-console",
                "deployment_id": "console-web",
                "host": "console-web"
              }
            }
          ]
        },
        {
          "name": "anmhela.com",
          "provider": "vercel",
          "desired_state": "present",
          "project": "cloud-console",
          "records": [
            {
              "type": "CNAME",
              "name": "c",
              "content": "cname.vercel-dns.com",
              "ttl": 300,
              "desired_state": "present",
              "deployment_link": {
                "project": "cloud-console",
                "deployment_id": "console-web",
                "host": "console-web"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "access-api",
      "desired_state": "present",
      "gcp": {
        "project_id": "my-gcp-project",
        "region": "us-central1",
        "services": [
          "run.googleapis.com",
          "secretmanager.googleapis.com",
          "sqladmin.googleapis.com"
        ]
      },
      "deployments": [
        {
          "name": "access-api",
          "provider": "gcp-cloud-run",
          "service": "access-api",
          "region": "us-central1",
          "environment": "production",
          "desired_state": "present"
        }
      ]
    },
    {
      "name": "omnichannel-api",
      "desired_state": "present",
      "gcp": {
        "project_id": "my-gcp-project",
        "region": "us-central1",
        "services": [
          "run.googleapis.com",
          "secretmanager.googleapis.com"
        ]
      },
      "deployments": [
        {
          "name": "omnichannel-api",
          "provider": "gcp-cloud-run",
          "service": "omnichannel-api",
          "region": "us-central1",
          "environment": "production",
          "desired_state": "present"
        }
      ]
    },
    {
      "name": "omnichannel-worker",
      "desired_state": "present",
      "gcp": {
        "project_id": "my-gcp-project",
        "region": "us-central1",
        "services": [
          "run.googleapis.com",
