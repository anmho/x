#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BIN_DIR="$ROOT_DIR/bin"
BIN_PATH="$BIN_DIR/platform"
MCP_BIN_PATH="$BIN_DIR/mcp"

build_binary() {
  mkdir -p "$BIN_DIR"
  (
    cd "$ROOT_DIR/platform-cli"
    GOCACHE=/tmp/go-cache go build -o "$BIN_PATH" .
  )
  echo "built: $BIN_PATH"
}

install_binary() {
  local target_dir="${1:-$HOME/.local/bin}"
  local target_path="$target_dir/platform"
  build_binary
  mkdir -p "$target_dir"
  install -m 0755 "$BIN_PATH" "$target_path"
  echo "installed: $target_path"
  echo "if needed, add this to PATH: export PATH=\"$target_dir:\$PATH\""
}

build_mcp_binary() {
  mkdir -p "$BIN_DIR"
  (
    cd "$ROOT_DIR/services/mcp"
    GOCACHE=/tmp/go-cache go build -o "$MCP_BIN_PATH" ./cmd/mcp
  )
  echo "built: $MCP_BIN_PATH"
}

case "${1:-}" in
  build)
    shift || true
    build_binary
    exit 0
    ;;
  install)
    shift || true
    install_binary "${1:-}"
    exit 0
    ;;
  mcp)
    shift || true
    if [[ ! -x "$MCP_BIN_PATH" ]]; then
      build_mcp_binary >/dev/null
    fi
    exec "$MCP_BIN_PATH" "$@"
    ;;
esac

if [[ -x "$BIN_PATH" ]]; then
  exec "$BIN_PATH" "$@"
fi

cd "$ROOT_DIR/platform-cli"
exec env GOCACHE=/tmp/go-cache go run . "$@"
