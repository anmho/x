{
  "name": "agent-runner",
  "root": "apps/agent-runner",
  "tags": ["layer:app", "lang:ts", "runtime:bun"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker build -t agent-runner apps/agent-runner",
        "cwd": "."
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun run dev",
        "cwd": "apps/agent-runner"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun test",
        "cwd": "apps/agent-runner"
      }
    }
  }
}
