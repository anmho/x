{
  "name": "omnichannel-frontend",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "npm run build", "cwd": "apps/omnichannel/frontend" },
      "dependsOn": ["sdk:generate-es"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "npm run lint", "cwd": "apps/omnichannel/frontend" }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "npm run test", "cwd": "apps/omnichannel/frontend" }
    }
  }
}
